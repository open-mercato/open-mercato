    "test:integration:ephemeral:start": "mercato test:ephemeral",
    "test:integration:ephemeral:start:verbose": "mercato test:ephemeral --verbose",
    "generate": "mercato generate",
    "install-skills": "sh scripts/install-skills.sh",
    "db:generate": "mercato db generate",
    "db:migrate": "mercato db migrate",
    "db:greenfield": "mercato db greenfield",
    "initialize": "mercato init",
    "reinstall": "mercato init --reinstall",
    "preinstall": "node -e \"const v = process.versions.node.split('.').map(Number); if (v[0] < 24) { console.error('Node >= 24 required'); process.exit(1); }\""
