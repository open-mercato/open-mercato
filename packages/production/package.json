{
  "name": "@open-mercato/production",
  "version": "0.6.6",
  "license": "MIT",
  "description": "Production planning for SMB discrete manufacturing: BOMs, routings, work centers, production orders, MRP, shop-floor reporting",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "node build.mjs",
    "watch": "node watch.mjs",
    "test": "jest --config jest.config.cjs",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": [
        "./src/*.ts",
        "./src/*.tsx"
      ],
      "default": "./dist/*.js"
    },
    "./*.json": "./src/*.json",
    "./*/*": {
      "types": [
        "./src/*/*.ts",
        "./src/*/*.tsx"
      ],
      "default": "./dist/*/*.js"
    },
    "./*/*.json": "./src/*/*.json",
    "./*/*/*": {
      "types": [
        "./src/*/*/*.ts",
        "./src/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*.js"
    },
    "./*/*/*.json": "./src/*/*/*.json",
    "./*/*/*/*": {
      "types": [
        "./src/*/*/*/*.ts",
        "./src/*/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*/*.js"
    },
    "./*/*/*/*.json": "./src/*/*/*/*.json",
    "./*/*/*/*/*": {
      "types": [
        "./src/*/*/*/*/*.ts",
        "./src/*/*/*/*/*.tsx"
      ],
      "default": "./dist/*/*/*/*/*.js"
    },
    "./*/*/*/*/*.json": "./src/*/*/*/*/*.json",
    "./*/*/*/*/*/*.json": "./src/*/*/*/*/*/*.json"
  },
  "dependencies": {
    "@open-mercato/core": "workspace:*"
  },
  "peerDependencies": {
    "@mikro-orm/core": "^7.0.14",
    "@open-mercato/shared": "workspace:*",
    "react": "^19.0.0",
    "zod": ">=3.23.0"
  },
  "devDependencies": {
    "@open-mercato/shared": "workspace:*",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "@types/react": "^19.0.0",
    "jest": "^30.4.2",
    "react": "^19.2.0",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/open-mercato/open-mercato",
    "directory": "packages/production"
  }
}
