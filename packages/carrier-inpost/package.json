{
  "name": "@open-mercato/carrier-inpost",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "node build.mjs",
    "watch": "node watch.mjs",
    "test": "jest --config jest.config.cjs",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": "./dist/index.js",
    "./modules/carrier_inpost": {
      "types": "./src/modules/carrier_inpost/index.ts",
      "default": "./dist/modules/carrier_inpost/index.js"
    },
    "./*": {
      "types": ["./src/*.ts", "./src/*.tsx"],
      "default": "./dist/*.js"
    },
    "./*/*": {
      "types": ["./src/*/*.ts", "./src/*/*.tsx"],
      "default": "./dist/*/*.js"
    },
    "./*/*/*": {
      "types": ["./src/*/*/*.ts", "./src/*/*/*.tsx"],
      "default": "./dist/*/*/*.js"
    },
    "./*/*/*/*": {
      "types": ["./src/*/*/*/*.ts", "./src/*/*/*/*.tsx"],
      "default": "./dist/*/*/*/*.js"
    },
    "./*/*/*/*/*": {
      "types": ["./src/*/*/*/*/*.ts", "./src/*/*/*/*/*.tsx"],
      "default": "./dist/*/*/*/*/*.js"
    }
  },
  "dependencies": {
    "@open-mercato/core": "workspace:*",
    "@open-mercato/shared": "workspace:*",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
