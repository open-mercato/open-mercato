{
  "name": "@open-mercato/cli",
  "version": "0.4.10",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./mercato": {
      "types": "./src/mercato.ts",
      "default": "./dist/mercato.js"
    },
    "./registry": {
      "types": "./src/registry.ts",
      "default": "./dist/registry.js"
    },
    "./*.ts": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    },
    "./*": {
      "types": [
        "./src/*.ts"
      ],
      "default": "./dist/*.js"
    },
    "./*/*": {
      "types": [
        "./src/*/*.ts"
      ],
      "default": "./dist/*/*.js"
    },
    "./*/*/*": {
      "types": [
        "./src/*/*/*.ts"
      ],
      "default": "./dist/*/*/*.js"
    },
    "./*/*/*/*": {
      "types": [
        "./src/*/*/*/*.ts"
      ],
      "default": "./dist/*/*/*/*.js"
    }
  },
  "bin": {
    "mercato": "./bin/mercato"
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node watch.mjs",
    "test": "jest --config jest.config.cjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@mikro-orm/core": "^7.0.10",
    "@mikro-orm/migrations": "^7.0.10",
    "@mikro-orm/postgresql": "^7.0.10",
    "@open-mercato/shared": "workspace:*",
    "pg": "8.20.0",
    "semver": "^7.7.3",
    "testcontainers": "^11.12.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@open-mercato/shared": "workspace:*"
  },
  "devDependencies": {
    "@open-mercato/shared": "workspace:*",
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
