{
  "name": "@open-mercato/cli",
  "version": "0.6.2",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./mercato": {
      "types": "./src/mercato.ts",
      "default": "./dist/mercato.js"
    },
    "./registry": {
      "types": "./src/registry.ts",
      "default": "./dist/registry.js"
    },
    "./*.ts": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    },
    "./*": {
      "types": [
        "./src/*.ts"
      ],
      "default": "./dist/*.js"
    },
    "./*/*": {
      "types": [
        "./src/*/*.ts"
      ],
      "default": "./dist/*/*.js"
    },
    "./*/*/*": {
      "types": [
        "./src/*/*/*.ts"
      ],
      "default": "./dist/*/*/*.js"
    },
    "./*/*/*/*": {
      "types": [
        "./src/*/*/*/*.ts"
      ],
      "default": "./dist/*/*/*/*.js"
    }
  },
  "bin": {
    "mercato": "./bin/mercato"
  },
  "scripts": {
    "build": "node build.mjs",
    "watch": "node watch.mjs",
    "test": "jest --config jest.config.cjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@mikro-orm/core": "^7.0.17",
    "@mikro-orm/decorators": "^7.0.17",
    "@mikro-orm/migrations": "^7.0.17",
    "@mikro-orm/postgresql": "^7.0.17",
    "@open-mercato/queue": "workspace:*",
    "@open-mercato/shared": "workspace:*",
    "cross-spawn": "^7.0.6",
    "pg": "8.21.0",
    "semver": "^7.8.0",
    "testcontainers": "^12.0.0",
    "ts-morph": "^28.0.0",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@open-mercato/shared": "workspace:*"
  },
  "devDependencies": {
    "@open-mercato/shared": "workspace:*",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/open-mercato/open-mercato",
    "directory": "packages/cli"
  }
}
