exports[`scaffold golden files omits statusMap and StatusBadge when no select field is named status: no-status backend/notes/[id]/page.tsx 1`] = `
""use client"

import * as React from 'react'
import { useRouter } from 'next/navigation'
import { Page, PageBody } from '@open-mercato/ui/backend/Page'
import { CrudForm } from '@open-mercato/ui/backend/CrudForm'
import { FormHeader } from '@open-mercato/ui/backend/forms/FormHeader'
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@open-mercato/ui/primitives/tabs'
import { LoadingMessage, ErrorMessage } from '@open-mercato/ui/backend/detail'
import { apiCall, withScopedApiRequestHeaders } from '@open-mercato/ui/backend/utils/apiCall'
import { updateCrud, deleteCrud } from '@open-mercato/ui/backend/utils/crud'
import { buildOptimisticLockHeader } from '@open-mercato/ui/backend/utils/optimisticLock'
import { useGuardedMutation } from '@open-mercato/ui/backend/injection/useGuardedMutation'
import { flash } from '@open-mercato/ui/backend/FlashMessages'
import { useConfirmDialog } from '@open-mercato/ui/backend/confirm-dialog'
import { useT } from '@open-mercato/shared/lib/i18n/context'
import { noteUpdateSchema, type NoteUpdateInput } from '../../../data/validators'
import {
  NOTE_ENTITY_ID,
  createNoteFormFields,
  createNoteFormGroups,
} from '../../../components/formConfig'

type NoteRecord = {
  id: string
  updatedAt?: string | null
  title: string
  body?: string | null
}

type NoteListResponse = {
  items: NoteRecord[]
}

export default function NoteDetailPage({ params }: { params?: { id?: string } }) {
  const t = useT()
  const router = useRouter()
  const id = typeof params?.id === 'string' ? params.id : null
  const { confirm, ConfirmDialogElement } = useConfirmDialog()
  const { runMutation } = useGuardedMutation({ contextId: 'notes.detail' })
  const [record, setRecord] = React.useState<NoteRecord | null>(null)
  const [isLoading, setIsLoading] = React.useState(true)
  const [loadError, setLoadError] = React.useState<string | null>(null)
  const [reloadToken, setReloadToken] = React.useState(0)

  React.useEffect(() => {
    let cancelled = false
    async function load() {
      if (!id) {
        setLoadError(t('notes.detail.notFound', 'Note not found'))
        setIsLoading(false)
        return
      }
      setIsLoading(true)
      setLoadError(null)
      try {
        const query = new URLSearchParams({ ids: id, pageSize: '1' })
        const call = await apiCall<NoteListResponse>('/api/notes?' + query.toString())
        if (cancelled) return
        if (!call.ok) {
          setLoadError(t('notes.detail.loadError', 'Failed to load note'))
          return
        }
        const item = call.result?.items?.[0] ?? null
        if (!item) {
          setLoadError(t('notes.detail.notFound', 'Note not found'))
          return
        }
        setRecord(item)
      } finally {
        if (!cancelled) setIsLoading(false)
      }
    }
    void load()
    return () => { cancelled = true }
  }, [id, reloadToken, t])

  const fields = React.useMemo(() => createNoteFormFields(t), [t])
  const groups = React.useMemo(() => createNoteFormGroups(t), [t])

  // updatedAt MUST stay in initialValues: CrudForm auto-derives the
  // x-om-ext-optimistic-lock-expected-updated-at header from it on submit AND delete.
  const initialValues = React.useMemo<Partial<NoteUpdateInput> | undefined>(() => {
    if (!record) return undefined
    return {
      id: record.id,
      updatedAt: record.updatedAt ?? undefined,
      title: record.title,
      body: record.body ?? undefined,
    }
  }, [record])

  const handleDelete = React.useCallback(async () => {
    if (!record) return
    const confirmed = await confirm({
      title: t('notes.delete.confirmTitle', 'Delete note?'),
      description: t('notes.delete.confirmDescription', 'This action cannot be undone.'),
      variant: 'destructive',
    })
    if (!confirmed) return
    try {
      await runMutation({
        operation: () =>
          withScopedApiRequestHeaders(
            buildOptimisticLockHeader(record.updatedAt ?? undefined),
            () => deleteCrud('notes', record.id),
          ),
        context: { resourceKind: 'notes.note', resourceId: record.id },
        mutationPayload: { id: record.id },
      })
      flash(t('notes.delete.success', 'Note deleted'), 'success')
      router.push('/backend/notes')
    } catch {
      flash(t('notes.delete.error', 'Failed to delete note'), 'error')
    }
  }, [confirm, record, router, runMutation, t])

  if (isLoading) {
    return (
      <Page>
        <PageBody>
          <LoadingMessage label={t('notes.detail.loading', 'Loading note')} />
        </PageBody>
      </Page>
    )
  }

  if (loadError || !record) {
    return (
      <Page>
        <PageBody>
          <ErrorMessage label={loadError ?? t('notes.detail.notFound', 'Note not found')} />
        </PageBody>
      </Page>
    )
  }

  return (
    <Page>
      <PageBody>
        <FormHeader
          mode="detail"
          backHref="/backend/notes"
          title={record.title}
          onDelete={() => { void handleDelete() }}
          deleteLabel={t('notes.detail.actions.delete', 'Delete')}
        />
        <Tabs defaultValue="overview" variant="underline" className="mt-4">
          <TabsList aria-label={t('notes.detail.tabs.label', 'Note sections')}>
            <TabsTrigger value="overview">{t('notes.detail.tabs.overview', 'Overview')}</TabsTrigger>
            {/* Extension point: add related-entity tabs here (activity, attachments, ...). */}
          </TabsList>
          <TabsContent value="overview">
            <CrudForm<NoteUpdateInput>
              schema={noteUpdateSchema}
              fields={fields}
              groups={groups}
              initialValues={initialValues}
              entityIds={[NOTE_ENTITY_ID]}
              submitLabel={t('notes.form.submit', 'Save')}
              onSubmit={async (values) => {
                await updateCrud('notes', values)
                flash(t('notes.detail.updateSuccess', 'Note updated'), 'success')
                setReloadToken((token) => token + 1)
              }}
            />
          </TabsContent>
        </Tabs>
      </PageBody>
      {ConfirmDialogElement}
    </Page>
  )
}
"
`;

