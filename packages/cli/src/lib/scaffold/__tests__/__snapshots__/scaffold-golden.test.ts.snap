exports[`scaffold golden files emits the full DS-compliant UI slice for every field type (app target): backend/inventory_items/create/page.tsx 1`] = `
""use client"

import * as React from 'react'
import { useRouter } from 'next/navigation'
import { Page, PageBody } from '@open-mercato/ui/backend/Page'
import { CrudForm } from '@open-mercato/ui/backend/CrudForm'
import { createCrud } from '@open-mercato/ui/backend/utils/crud'
import { flash } from '@open-mercato/ui/backend/FlashMessages'
import { useT } from '@open-mercato/shared/lib/i18n/context'
import {
  STOCK_ITEM_ENTITY_ID,
  createStockItemFormFields,
  createStockItemFormGroups,
  createStockItemFormSchema,
  type StockItemFormValues,
} from '../../../components/formConfig'

export default function StockItemCreatePage() {
  const t = useT()
  const router = useRouter()
  const schema = React.useMemo(() => createStockItemFormSchema(), [])
  const fields = React.useMemo(() => createStockItemFormFields(t), [t])
  const groups = React.useMemo(() => createStockItemFormGroups(t), [t])

  return (
    <Page>
      <PageBody>
        <CrudForm<StockItemFormValues>
          title={t('inventory_items.create.title', 'Create stock item')}
          backHref="/backend/inventory_items"
          cancelHref="/backend/inventory_items"
          schema={schema}
          fields={fields}
          groups={groups}
          entityIds={[STOCK_ITEM_ENTITY_ID]}
          submitLabel={t('inventory_items.form.submit', 'Save')}
          onSubmit={async (values) => {
            const call = await createCrud<{ id?: string }>('inventory_items', values)
            const createdId = typeof call.result?.id === 'string' ? call.result.id : null
            flash(t('inventory_items.create.success', 'Stock item created'), 'success')
            router.push(createdId ? '/backend/inventory_items/' + createdId : '/backend/inventory_items')
          }}
        />
      </PageBody>
    </Page>
  )
}
"
`;

