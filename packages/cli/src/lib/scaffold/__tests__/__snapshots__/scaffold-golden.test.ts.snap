exports[`scaffold golden files emits the full DS-compliant UI slice for every field type (app target): backend/inventory_items/[id]/page.tsx 1`] = `
""use client"

import * as React from 'react'
import { useRouter } from 'next/navigation'
import { Page, PageBody } from '@open-mercato/ui/backend/Page'
import { CrudForm } from '@open-mercato/ui/backend/CrudForm'
import { FormHeader } from '@open-mercato/ui/backend/forms/FormHeader'
import { Tabs, TabsContent, TabsList, TabsTrigger } from '@open-mercato/ui/primitives/tabs'
import { LoadingMessage, ErrorMessage } from '@open-mercato/ui/backend/detail'
import { apiCall, withScopedApiRequestHeaders } from '@open-mercato/ui/backend/utils/apiCall'
import { updateCrud, deleteCrud } from '@open-mercato/ui/backend/utils/crud'
import { buildOptimisticLockHeader } from '@open-mercato/ui/backend/utils/optimisticLock'
import { useGuardedMutation } from '@open-mercato/ui/backend/injection/useGuardedMutation'
import { flash } from '@open-mercato/ui/backend/FlashMessages'
import { useConfirmDialog } from '@open-mercato/ui/backend/confirm-dialog'
import { useT } from '@open-mercato/shared/lib/i18n/context'
import { stockItemUpdateSchema, type StockItemUpdateInput } from '../../../data/validators'
import { StatusBadge } from '@open-mercato/ui/primitives/status-badge'
import { stockItemStatusMap, type StockItemStatus } from '../../../components/statusMap'
import {
  STOCK_ITEM_ENTITY_ID,
  createStockItemFormFields,
  createStockItemFormGroups,
} from '../../../components/formConfig'

type StockItemRecord = {
  id: string
  updatedAt?: string | null
  name: string
  summary?: string | null
  quantity: number
  status?: StockItemStatus | null
  severity: 'low' | 'high'
  archived?: boolean | null
  dueDate: string
}

type StockItemListResponse = {
  items: StockItemRecord[]
}

export default function StockItemDetailPage({ params }: { params?: { id?: string } }) {
  const t = useT()
  const router = useRouter()
  const id = typeof params?.id === 'string' ? params.id : null
  const { confirm, ConfirmDialogElement } = useConfirmDialog()
  const { runMutation } = useGuardedMutation({ contextId: 'inventory_items.detail' })
  const [record, setRecord] = React.useState<StockItemRecord | null>(null)
  const [isLoading, setIsLoading] = React.useState(true)
  const [loadError, setLoadError] = React.useState<string | null>(null)
  const [reloadToken, setReloadToken] = React.useState(0)

  React.useEffect(() => {
    let cancelled = false
    async function load() {
      if (!id) {
        setLoadError(t('inventory_items.detail.notFound', 'Stock item not found'))
        setIsLoading(false)
        return
      }
      setIsLoading(true)
      setLoadError(null)
      try {
        const query = new URLSearchParams({ ids: id, pageSize: '1' })
        const call = await apiCall<StockItemListResponse>('/api/inventory_items?' + query.toString())
        if (cancelled) return
        if (!call.ok) {
          setLoadError(t('inventory_items.detail.loadError', 'Failed to load stock item'))
          return
        }
        const item = call.result?.items?.[0] ?? null
        if (!item) {
          setLoadError(t('inventory_items.detail.notFound', 'Stock item not found'))
          return
        }
        setRecord(item)
      } finally {
        if (!cancelled) setIsLoading(false)
      }
    }
    void load()
    return () => { cancelled = true }
  }, [id, reloadToken, t])

  const fields = React.useMemo(() => createStockItemFormFields(t), [t])
  const groups = React.useMemo(() => createStockItemFormGroups(t), [t])

  // updatedAt MUST stay in initialValues: CrudForm auto-derives the
  // x-om-ext-optimistic-lock-expected-updated-at header from it on submit AND delete.
  const initialValues = React.useMemo<Partial<StockItemUpdateInput> | undefined>(() => {
    if (!record) return undefined
    return {
      id: record.id,
      updatedAt: record.updatedAt ?? undefined,
      name: record.name,
      summary: record.summary ?? undefined,
      quantity: record.quantity,
      status: record.status ?? undefined,
      severity: record.severity,
      archived: record.archived ?? undefined,
      dueDate: record.dueDate ? new Date(record.dueDate) : undefined,
    }
  }, [record])

  const handleDelete = React.useCallback(async () => {
    if (!record) return
    const confirmed = await confirm({
      title: t('inventory_items.delete.confirmTitle', 'Delete stock item?'),
      description: t('inventory_items.delete.confirmDescription', 'This action cannot be undone.'),
      variant: 'destructive',
    })
    if (!confirmed) return
    try {
      await runMutation({
        operation: () =>
          withScopedApiRequestHeaders(
            buildOptimisticLockHeader(record.updatedAt ?? undefined),
            () => deleteCrud('inventory_items', record.id),
          ),
        context: { resourceKind: 'inventory_items.stock_item', resourceId: record.id },
        mutationPayload: { id: record.id },
      })
      flash(t('inventory_items.delete.success', 'Stock item deleted'), 'success')
      router.push('/backend/inventory_items')
    } catch {
      flash(t('inventory_items.delete.error', 'Failed to delete stock item'), 'error')
    }
  }, [confirm, record, router, runMutation, t])

  if (isLoading) {
    return (
      <Page>
        <PageBody>
          <LoadingMessage label={t('inventory_items.detail.loading', 'Loading stock item')} />
        </PageBody>
      </Page>
    )
  }

  if (loadError || !record) {
    return (
      <Page>
        <PageBody>
          <ErrorMessage label={loadError ?? t('inventory_items.detail.notFound', 'Stock item not found')} />
        </PageBody>
      </Page>
    )
  }

  return (
    <Page>
      <PageBody>
        <FormHeader
          mode="detail"
          backHref="/backend/inventory_items"
          title={record.name}
          statusBadge={record.status ? (
            <StatusBadge variant={stockItemStatusMap[record.status] ?? 'neutral'} dot>
              {t('inventory_items.fields.status.options.' + record.status, record.status)}
            </StatusBadge>
          ) : undefined}
          onDelete={() => { void handleDelete() }}
          deleteLabel={t('inventory_items.detail.actions.delete', 'Delete')}
        />
        <Tabs defaultValue="overview" variant="underline" className="mt-4">
          <TabsList aria-label={t('inventory_items.detail.tabs.label', 'Stock item sections')}>
            <TabsTrigger value="overview">{t('inventory_items.detail.tabs.overview', 'Overview')}</TabsTrigger>
            {/* Extension point: add related-entity tabs here (activity, attachments, ...). */}
          </TabsList>
          <TabsContent value="overview">
            <CrudForm<StockItemUpdateInput>
              schema={stockItemUpdateSchema}
              fields={fields}
              groups={groups}
              initialValues={initialValues}
              entityIds={[STOCK_ITEM_ENTITY_ID]}
              submitLabel={t('inventory_items.form.submit', 'Save')}
              onSubmit={async (values) => {
                await updateCrud('inventory_items', values)
                flash(t('inventory_items.detail.updateSuccess', 'Stock item updated'), 'success')
                setReloadToken((token) => token + 1)
              }}
            />
          </TabsContent>
        </Tabs>
      </PageBody>
      {ConfirmDialogElement}
    </Page>
  )
}
"
`;

