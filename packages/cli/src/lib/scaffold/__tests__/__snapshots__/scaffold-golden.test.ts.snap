exports[`scaffold golden files emits the full DS-compliant UI slice for every field type (app target): backend/inventory_items/page.tsx 1`] = `
""use client"

import * as React from 'react'
import Link from 'next/link'
import { useRouter } from 'next/navigation'
import { Page, PageBody } from '@open-mercato/ui/backend/Page'
import { DataTable, type DataTableExportFormat } from '@open-mercato/ui/backend/DataTable'
import type { ColumnDef } from '@tanstack/react-table'
import { Button } from '@open-mercato/ui/primitives/button'
import { EmptyState } from '@open-mercato/ui/primitives/empty-state'
import { RowActions } from '@open-mercato/ui/backend/RowActions'
import { apiCall, withScopedApiRequestHeaders } from '@open-mercato/ui/backend/utils/apiCall'
import { buildCrudExportUrl, deleteCrud } from '@open-mercato/ui/backend/utils/crud'
import { buildOptimisticLockHeader } from '@open-mercato/ui/backend/utils/optimisticLock'
import { useGuardedMutation } from '@open-mercato/ui/backend/injection/useGuardedMutation'
import { flash } from '@open-mercato/ui/backend/FlashMessages'
import { useConfirmDialog } from '@open-mercato/ui/backend/confirm-dialog'
import { useT } from '@open-mercato/shared/lib/i18n/context'
import type { FilterDef, FilterValues } from '@open-mercato/ui/backend/FilterOverlay'
import { StatusBadge } from '@open-mercato/ui/primitives/status-badge'
import { stockItemStatusMap, type StockItemStatus } from '../../components/statusMap'

type StockItemRow = {
  id: string
  updatedAt?: string | null
  name: string
  summary?: string | null
  quantity: number
  status?: StockItemStatus | null
  severity: 'low' | 'high'
  archived?: boolean | null
  dueDate: string
}

type StockItemListResponse = {
  items: StockItemRow[]
  total: number
  totalPages: number
}

// DS guardrail: keep pageSize at or below 100.
const PAGE_SIZE = 25

export default function StockItemListPage() {
  const t = useT()
  const router = useRouter()
  const { confirm, ConfirmDialogElement } = useConfirmDialog()
  const { runMutation } = useGuardedMutation({ contextId: 'inventory_items.list' })
  const [rows, setRows] = React.useState<StockItemRow[]>([])
  const [isLoading, setIsLoading] = React.useState(true)
  const [page, setPage] = React.useState(1)
  const [total, setTotal] = React.useState(0)
  const [totalPages, setTotalPages] = React.useState(1)
  const [search, setSearch] = React.useState('')
  const [filterValues, setFilterValues] = React.useState<FilterValues>({})
  const [reloadToken, setReloadToken] = React.useState(0)

  const listParams = React.useMemo(() => {
    const params: Record<string, string | number> = { page, pageSize: PAGE_SIZE }
    if (search) params.search = search
    if (typeof filterValues.status === 'string' && filterValues.status) params.status = filterValues.status
    if (typeof filterValues.severity === 'string' && filterValues.severity) params.severity = filterValues.severity
    return params
  }, [filterValues, page, search])

  React.useEffect(() => {
    let cancelled = false
    async function load() {
      setIsLoading(true)
      try {
        const query = new URLSearchParams()
        for (const [key, value] of Object.entries(listParams)) query.set(key, String(value))
        const fallback: StockItemListResponse = { items: [], total: 0, totalPages: 1 }
        const call = await apiCall<StockItemListResponse>('/api/inventory_items?' + query.toString(), undefined, { fallback })
        if (cancelled) return
        if (!call.ok) {
          flash(t('inventory_items.list.loadError', 'Failed to load inventory items'), 'error')
          return
        }
        const result = call.result ?? fallback
        setRows(result.items)
        setTotal(result.total)
        setTotalPages(result.totalPages)
      } finally {
        if (!cancelled) setIsLoading(false)
      }
    }
    void load()
    return () => { cancelled = true }
  }, [listParams, reloadToken, t])

  const handleDelete = React.useCallback(async (row: StockItemRow) => {
    const confirmed = await confirm({
      title: t('inventory_items.delete.confirmTitle', 'Delete stock item?'),
      description: t('inventory_items.delete.confirmDescription', 'This action cannot be undone.'),
      variant: 'destructive',
    })
    if (!confirmed) return
    try {
      // Optimistic locking is ON by default: derive the expected-updated-at
      // header from the row the user acted on.
      await runMutation({
        operation: () =>
          withScopedApiRequestHeaders(
            buildOptimisticLockHeader(row.updatedAt ?? undefined),
            () => deleteCrud('inventory_items', row.id),
          ),
        context: { resourceKind: 'inventory_items.stock_item', resourceId: row.id },
        mutationPayload: { id: row.id },
      })
      flash(t('inventory_items.delete.success', 'Stock item deleted'), 'success')
      setReloadToken((token) => token + 1)
    } catch {
      flash(t('inventory_items.delete.error', 'Failed to delete stock item'), 'error')
    }
  }, [confirm, runMutation, t])

  const columns = React.useMemo<ColumnDef<StockItemRow>[]>(() => [
    { accessorKey: 'name', header: t('inventory_items.fields.name', 'Name') },
    {
      accessorKey: 'quantity',
      header: t('inventory_items.fields.quantity', 'Quantity'),
      cell: ({ row }) => <div className="text-right tabular-nums">{row.original.quantity ?? null}</div>,
    },
    {
      accessorKey: 'status',
      header: t('inventory_items.fields.status', 'Status'),
      cell: ({ row }) => {
        const status = row.original.status
        if (!status) return null
        return (
          <StatusBadge variant={stockItemStatusMap[status] ?? 'neutral'} dot>
            {t('inventory_items.fields.status.options.' + status, status)}
          </StatusBadge>
        )
      },
    },
    {
      accessorKey: 'severity',
      header: t('inventory_items.fields.severity', 'Severity'),
      cell: ({ row }) => (row.original.severity ? t('inventory_items.fields.severity.options.' + row.original.severity, row.original.severity) : null),
    },
    {
      accessorKey: 'archived',
      header: t('inventory_items.fields.archived', 'Archived'),
      cell: ({ row }) => (row.original.archived ? t('inventory_items.list.boolean.yes', 'Yes') : t('inventory_items.list.boolean.no', 'No')),
    },
    {
      accessorKey: 'dueDate',
      header: t('inventory_items.fields.dueDate', 'Due date'),
      cell: ({ row }) => (row.original.dueDate ? new Date(row.original.dueDate as string).toLocaleDateString() : null),
    },
  ], [t])

  const filters = React.useMemo<FilterDef[]>(() => [
    {
      id: 'status',
      label: t('inventory_items.fields.status', 'Status'),
      type: 'select',
      options: [
        { value: 'open', label: t('inventory_items.fields.status.options.open', 'Open') },
        { value: 'in_progress', label: t('inventory_items.fields.status.options.in_progress', 'In progress') },
        { value: 'closed', label: t('inventory_items.fields.status.options.closed', 'Closed') },
      ],
    },
    {
      id: 'severity',
      label: t('inventory_items.fields.severity', 'Severity'),
      type: 'select',
      options: [
        { value: 'low', label: t('inventory_items.fields.severity.options.low', 'Low') },
        { value: 'high', label: t('inventory_items.fields.severity.options.high', 'High') },
      ],
    },
  ], [t])

  const exporter = React.useMemo(() => ({
    getUrl: (format: DataTableExportFormat) => buildCrudExportUrl('inventory_items', { ...listParams, exportScope: 'view' }, format),
    filename: (format: DataTableExportFormat) => 'inventory_items.' + format,
  }), [listParams])

  return (
    <Page>
      <PageBody>
        <DataTable<StockItemRow>
          title={t('inventory_items.list.title', 'Inventory items')}
          actions={(
            <Button asChild>
              <Link href="/backend/inventory_items/create">{t('inventory_items.list.actions.create', 'Create stock item')}</Link>
            </Button>
          )}
          columns={columns}
          data={rows}
          isLoading={isLoading}
          searchValue={search}
          onSearchChange={(value) => { setSearch(value); setPage(1) }}
          searchPlaceholder={t('inventory_items.list.searchPlaceholder', 'Search inventory items')}
          filters={filters}
          filterValues={filterValues}
          onFiltersApply={(values) => { setFilterValues(values); setPage(1) }}
          onFiltersClear={() => { setFilterValues({}); setPage(1) }}
          exporter={exporter}
          extensionTableId="inventory_items.list"
          onRowClick={(row) => router.push('/backend/inventory_items/' + row.id)}
          rowActions={(row) => (
            <RowActions
              items={[
                {
                  id: 'edit',
                  label: t('inventory_items.list.actions.edit', 'Edit'),
                  onSelect: () => { router.push('/backend/inventory_items/' + row.id) },
                },
                {
                  id: 'delete',
                  label: t('inventory_items.list.actions.delete', 'Delete'),
                  destructive: true,
                  onSelect: () => { void handleDelete(row) },
                },
              ]}
            />
          )}
          emptyState={(
            <EmptyState
              title={t('inventory_items.list.empty.title', 'No inventory items yet')}
              description={t('inventory_items.list.empty.description', 'Create your first stock item to get started.')}
              actions={(
                <Button asChild>
                  <Link href="/backend/inventory_items/create">{t('inventory_items.list.actions.create', 'Create stock item')}</Link>
                </Button>
              )}
            />
          )}
          pagination={{ page, pageSize: PAGE_SIZE, total, totalPages, onPageChange: setPage }}
        />
      </PageBody>
      {ConfirmDialogElement}
    </Page>
  )
}
"
`;

exports[`scaffold golden files emits the full DS-compliant UI slice for every field type (app target): components/formConfig.ts 1`] = `
"import { z } from 'zod'
import type { CrudField, CrudFormGroup } from '@open-mercato/ui/backend/CrudForm'
import type { TranslateFn } from '@open-mercato/shared/lib/i18n/context'
import { stockItemCreateSchema } from '../data/validators'

/** Entity id used to load custom-field sets once the module declares \`ce.ts\`. */
export const STOCK_ITEM_ENTITY_ID = 'inventory_items:stock_item'

export type StockItemFormValues = z.infer<typeof stockItemCreateSchema>

export function createStockItemFormSchema() {
  return stockItemCreateSchema
}

export function createStockItemFormFields(t: TranslateFn): CrudField[] {
  return [
    { id: 'name', label: t('inventory_items.fields.name', 'Name'), type: 'text', required: true },
    { id: 'summary', label: t('inventory_items.fields.summary', 'Summary'), type: 'textarea' },
    { id: 'quantity', label: t('inventory_items.fields.quantity', 'Quantity'), type: 'number', required: true },
    {
      id: 'status',
      label: t('inventory_items.fields.status', 'Status'),
      type: 'select',
      options: [
        { value: 'open', label: t('inventory_items.fields.status.options.open', 'Open') },
        { value: 'in_progress', label: t('inventory_items.fields.status.options.in_progress', 'In progress') },
        { value: 'closed', label: t('inventory_items.fields.status.options.closed', 'Closed') },
      ],
    },
    {
      id: 'severity',
      label: t('inventory_items.fields.severity', 'Severity'),
      type: 'select',
      required: true,
      options: [
        { value: 'low', label: t('inventory_items.fields.severity.options.low', 'Low') },
        { value: 'high', label: t('inventory_items.fields.severity.options.high', 'High') },
      ],
    },
    { id: 'archived', label: t('inventory_items.fields.archived', 'Archived'), type: 'checkbox' },
    { id: 'dueDate', label: t('inventory_items.fields.dueDate', 'Due date'), type: 'date', required: true },
  ]
}

export function createStockItemFormGroups(t: TranslateFn): CrudFormGroup[] {
  return [
    {
      id: 'details',
      title: t('inventory_items.form.groups.details', 'Details'),
      column: 1,
      fields: ['name', 'summary', 'quantity', 'status', 'severity', 'archived', 'dueDate'],
    },
    // Custom-field sets registered for STOCK_ITEM_ENTITY_ID render here.
    {
      id: 'attributes',
      title: t('inventory_items.form.groups.attributes', 'Attributes'),
      column: 2,
      kind: 'customFields',
    },
  ]
}
"
`;

exports[`scaffold golden files emits the full DS-compliant UI slice for every field type (app target): components/statusMap.ts 1`] = `
"import type { StatusMap } from '@open-mercato/ui/primitives/status-badge'

export type StockItemStatus = 'open' | 'in_progress' | 'closed'

// Shared status → semantic-variant mapping (DS rule: status colors come from
// StatusBadge variants, never hardcoded palette classes).
export const stockItemStatusMap: StatusMap<StockItemStatus> = {
  open: 'info',
  in_progress: 'info',
  closed: 'neutral',
}
"
`;

exports[`scaffold golden files emits the full DS-compliant UI slice for every field type (app target): data/validators.ts 1`] = `
"import { z } from 'zod'

// Optimistic locking is ON by default for CrudForm edit flows: the stock item
// API responses MUST return \`updatedAt\` and the backing table MUST carry an
// \`updated_at\` column so \`initialValues.updatedAt\` can drive the
// x-om-ext-optimistic-lock-expected-updated-at header on update and delete.
export const stockItemCreateSchema = z.object({
  name: z.string().min(1),
  summary: z.string().optional(),
  quantity: z.coerce.number(),
  status: z.enum(['open', 'in_progress', 'closed']).optional(),
  severity: z.enum(['low', 'high']),
  archived: z.boolean().optional(),
  dueDate: z.coerce.date(),
})

export const stockItemUpdateSchema = stockItemCreateSchema.extend({
  id: z.string().uuid(),
  updatedAt: z.string().optional(),
})

export type StockItemCreateInput = z.infer<typeof stockItemCreateSchema>
export type StockItemUpdateInput = z.infer<typeof stockItemUpdateSchema>
"
`;

