exports[`scaffold golden files omits statusMap and StatusBadge when no select field is named status: no-status backend/notes/create/page.tsx 1`] = `
""use client"

import * as React from 'react'
import { useRouter } from 'next/navigation'
import { Page, PageBody } from '@open-mercato/ui/backend/Page'
import { CrudForm } from '@open-mercato/ui/backend/CrudForm'
import { createCrud } from '@open-mercato/ui/backend/utils/crud'
import { flash } from '@open-mercato/ui/backend/FlashMessages'
import { useT } from '@open-mercato/shared/lib/i18n/context'
import {
  NOTE_ENTITY_ID,
  createNoteFormFields,
  createNoteFormGroups,
  createNoteFormSchema,
  type NoteFormValues,
} from '../../../components/formConfig'

export default function NoteCreatePage() {
  const t = useT()
  const router = useRouter()
  const schema = React.useMemo(() => createNoteFormSchema(), [])
  const fields = React.useMemo(() => createNoteFormFields(t), [t])
  const groups = React.useMemo(() => createNoteFormGroups(t), [t])

  return (
    <Page>
      <PageBody>
        <CrudForm<NoteFormValues>
          title={t('notes.create.title', 'Create note')}
          backHref="/backend/notes"
          cancelHref="/backend/notes"
          schema={schema}
          fields={fields}
          groups={groups}
          entityIds={[NOTE_ENTITY_ID]}
          submitLabel={t('notes.form.submit', 'Save')}
          onSubmit={async (values) => {
            const call = await createCrud<{ id?: string }>('notes', values)
            const createdId = typeof call.result?.id === 'string' ? call.result.id : null
            flash(t('notes.create.success', 'Note created'), 'success')
            router.push(createdId ? '/backend/notes/' + createdId : '/backend/notes')
          }}
        />
      </PageBody>
    </Page>
  )
}
"
`;

