exports[`scaffold golden files omits statusMap and StatusBadge when no select field is named status: no-status backend/notes/page.tsx 1`] = `
""use client"

import * as React from 'react'
import Link from 'next/link'
import { useRouter } from 'next/navigation'
import { Page, PageBody } from '@open-mercato/ui/backend/Page'
import { DataTable, type DataTableExportFormat } from '@open-mercato/ui/backend/DataTable'
import type { ColumnDef } from '@tanstack/react-table'
import { Button } from '@open-mercato/ui/primitives/button'
import { EmptyState } from '@open-mercato/ui/primitives/empty-state'
import { RowActions } from '@open-mercato/ui/backend/RowActions'
import { apiCall, withScopedApiRequestHeaders } from '@open-mercato/ui/backend/utils/apiCall'
import { buildCrudExportUrl, deleteCrud } from '@open-mercato/ui/backend/utils/crud'
import { buildOptimisticLockHeader } from '@open-mercato/ui/backend/utils/optimisticLock'
import { useGuardedMutation } from '@open-mercato/ui/backend/injection/useGuardedMutation'
import { flash } from '@open-mercato/ui/backend/FlashMessages'
import { useConfirmDialog } from '@open-mercato/ui/backend/confirm-dialog'
import { useT } from '@open-mercato/shared/lib/i18n/context'

type NoteRow = {
  id: string
  updatedAt?: string | null
  title: string
  body?: string | null
}

type NoteListResponse = {
  items: NoteRow[]
  total: number
  totalPages: number
}

// DS guardrail: keep pageSize at or below 100.
const PAGE_SIZE = 25

export default function NoteListPage() {
  const t = useT()
  const router = useRouter()
  const { confirm, ConfirmDialogElement } = useConfirmDialog()
  const { runMutation } = useGuardedMutation({ contextId: 'notes.list' })
  const [rows, setRows] = React.useState<NoteRow[]>([])
  const [isLoading, setIsLoading] = React.useState(true)
  const [page, setPage] = React.useState(1)
  const [total, setTotal] = React.useState(0)
  const [totalPages, setTotalPages] = React.useState(1)
  const [search, setSearch] = React.useState('')
  const [reloadToken, setReloadToken] = React.useState(0)

  const listParams = React.useMemo(() => {
    const params: Record<string, string | number> = { page, pageSize: PAGE_SIZE }
    if (search) params.search = search
    return params
  }, [page, search])

  React.useEffect(() => {
    let cancelled = false
    async function load() {
      setIsLoading(true)
      try {
        const query = new URLSearchParams()
        for (const [key, value] of Object.entries(listParams)) query.set(key, String(value))
        const fallback: NoteListResponse = { items: [], total: 0, totalPages: 1 }
        const call = await apiCall<NoteListResponse>('/api/notes?' + query.toString(), undefined, { fallback })
        if (cancelled) return
        if (!call.ok) {
          flash(t('notes.list.loadError', 'Failed to load notes'), 'error')
          return
        }
        const result = call.result ?? fallback
        setRows(result.items)
        setTotal(result.total)
        setTotalPages(result.totalPages)
      } finally {
        if (!cancelled) setIsLoading(false)
      }
    }
    void load()
    return () => { cancelled = true }
  }, [listParams, reloadToken, t])

  const handleDelete = React.useCallback(async (row: NoteRow) => {
    const confirmed = await confirm({
      title: t('notes.delete.confirmTitle', 'Delete note?'),
      description: t('notes.delete.confirmDescription', 'This action cannot be undone.'),
      variant: 'destructive',
    })
    if (!confirmed) return
    try {
      // Optimistic locking is ON by default: derive the expected-updated-at
      // header from the row the user acted on.
      await runMutation({
        operation: () =>
          withScopedApiRequestHeaders(
            buildOptimisticLockHeader(row.updatedAt ?? undefined),
            () => deleteCrud('notes', row.id),
          ),
        context: { resourceKind: 'notes.note', resourceId: row.id },
        mutationPayload: { id: row.id },
      })
      flash(t('notes.delete.success', 'Note deleted'), 'success')
      setReloadToken((token) => token + 1)
    } catch {
      flash(t('notes.delete.error', 'Failed to delete note'), 'error')
    }
  }, [confirm, runMutation, t])

  const columns = React.useMemo<ColumnDef<NoteRow>[]>(() => [
    { accessorKey: 'title', header: t('notes.fields.title', 'Title') },
  ], [t])

  const exporter = React.useMemo(() => ({
    getUrl: (format: DataTableExportFormat) => buildCrudExportUrl('notes', { ...listParams, exportScope: 'view' }, format),
    filename: (format: DataTableExportFormat) => 'notes.' + format,
  }), [listParams])

  return (
    <Page>
      <PageBody>
        <DataTable<NoteRow>
          title={t('notes.list.title', 'Notes')}
          actions={(
            <Button asChild>
              <Link href="/backend/notes/create">{t('notes.list.actions.create', 'Create note')}</Link>
            </Button>
          )}
          columns={columns}
          data={rows}
          isLoading={isLoading}
          searchValue={search}
          onSearchChange={(value) => { setSearch(value); setPage(1) }}
          searchPlaceholder={t('notes.list.searchPlaceholder', 'Search notes')}
          exporter={exporter}
          extensionTableId="notes.list"
          onRowClick={(row) => router.push('/backend/notes/' + row.id)}
          rowActions={(row) => (
            <RowActions
              items={[
                {
                  id: 'edit',
                  label: t('notes.list.actions.edit', 'Edit'),
                  onSelect: () => { router.push('/backend/notes/' + row.id) },
                },
                {
                  id: 'delete',
                  label: t('notes.list.actions.delete', 'Delete'),
                  destructive: true,
                  onSelect: () => { void handleDelete(row) },
                },
              ]}
            />
          )}
          emptyState={(
            <EmptyState
              title={t('notes.list.empty.title', 'No notes yet')}
              description={t('notes.list.empty.description', 'Create your first note to get started.')}
              actions={(
                <Button asChild>
                  <Link href="/backend/notes/create">{t('notes.list.actions.create', 'Create note')}</Link>
                </Button>
              )}
            />
          )}
          pagination={{ page, pageSize: PAGE_SIZE, total, totalPages, onPageChange: setPage }}
        />
      </PageBody>
      {ConfirmDialogElement}
    </Page>
  )
}
"
`;

exports[`scaffold golden files omits statusMap and StatusBadge when no select field is named status: no-status components/formConfig.ts 1`] = `
"import { z } from 'zod'
import type { CrudField, CrudFormGroup } from '@open-mercato/ui/backend/CrudForm'
import type { TranslateFn } from '@open-mercato/shared/lib/i18n/context'
import { noteCreateSchema } from '../data/validators'

/** Entity id used to load custom-field sets once the module declares \`ce.ts\`. */
export const NOTE_ENTITY_ID = 'notes:note'

export type NoteFormValues = z.infer<typeof noteCreateSchema>

export function createNoteFormSchema() {
  return noteCreateSchema
}

export function createNoteFormFields(t: TranslateFn): CrudField[] {
  return [
    { id: 'title', label: t('notes.fields.title', 'Title'), type: 'text', required: true },
    { id: 'body', label: t('notes.fields.body', 'Body'), type: 'textarea' },
  ]
}

export function createNoteFormGroups(t: TranslateFn): CrudFormGroup[] {
  return [
    {
      id: 'details',
      title: t('notes.form.groups.details', 'Details'),
      column: 1,
      fields: ['title', 'body'],
    },
    // Custom-field sets registered for NOTE_ENTITY_ID render here.
    {
      id: 'attributes',
      title: t('notes.form.groups.attributes', 'Attributes'),
      column: 2,
      kind: 'customFields',
    },
  ]
}
"
`;

exports[`scaffold golden files omits statusMap and StatusBadge when no select field is named status: no-status data/validators.ts 1`] = `
"import { z } from 'zod'

// Optimistic locking is ON by default for CrudForm edit flows: the note
// API responses MUST return \`updatedAt\` and the backing table MUST carry an
// \`updated_at\` column so \`initialValues.updatedAt\` can drive the
// x-om-ext-optimistic-lock-expected-updated-at header on update and delete.
export const noteCreateSchema = z.object({
  title: z.string().min(1),
  body: z.string().optional(),
})

export const noteUpdateSchema = noteCreateSchema.extend({
  id: z.string().uuid(),
  updatedAt: z.string().optional(),
})

export type NoteCreateInput = z.infer<typeof noteCreateSchema>
export type NoteUpdateInput = z.infer<typeof noteUpdateSchema>
"
`;

