{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["*"],
  "globalDependencies": ["packages/create-app/agentic/**"],
  "tasks": {
    "build": {
      "inputs": [
        "src/**/*.{ts,tsx}",
        "generated/**/*.{ts,tsx}",
        "src/**/*.json",
        "build.mjs",
        "build.config.mjs",
        "package.json",
        "tsconfig.json"
      ],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "dependsOn": ["^build"]
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "watch": {
      "cache": false,
      "persistent": true
    },
    "mcp:dev": {
      "cache": false,
      "persistent": true
    },
    "mcp:serve": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "cache": false,
      "outputs": []
    },
    "test": {
      "cache": false,
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "generate": {
      "cache": false,
      "outputs": [".mercato/**"]
    },
    "db:generate": {
      "cache": false,
      "outputs": []
    },
    "db:migrate": {
      "cache": false,
      "outputs": []
    },
    "db:greenfield": {
      "cache": false,
      "outputs": []
    },
    "reinstall": {
      "cache": false,
      "outputs": []
    },
    "initialize": {
      "cache": false,
      "outputs": []
    }
  }
}
