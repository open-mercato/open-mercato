{
  "name": "open-mercato",
  "version": "0.6.6",
  "private": true,
  "packageManager": "yarn@4.17.1+sha512.ccbfabf7d7b6b32075088be9386fb9a2e00bb6887ef07fa56effabc890a56d53da1ccc4128d62db245fcbd3961b236d75335bdf7d5320ed6eafb7588b7ad4697",
  "engines": {
    "node": "24.x"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "external/official-modules/packages/*"
  ],
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:classic": "node ./scripts/dev.mjs --classic",
    "dev:verbose": "node ./scripts/dev.mjs --verbose",
    "dev:ephemeral": "tsx scripts/dev-ephemeral.ts",
    "dev:ephemeral:classic": "tsx scripts/dev-ephemeral.ts --classic",
    "dev:ephemeral:verbose": "tsx scripts/dev-ephemeral.ts --verbose",
    "dev:greenfield": "node ./scripts/dev.mjs --greenfield",
    "dev:greenfield:classic": "node ./scripts/dev.mjs --greenfield --classic",
    "dev:greenfield:verbose": "node ./scripts/dev.mjs --greenfield --verbose",
    "dev:app": "node ./scripts/dev.mjs --app-only",
    "dev:app:verbose": "yarn workspace @open-mercato/app dev:verbose",
    "dev:fix-wsl-watchers": "node ./scripts/fix-wsl-inotify.mjs",
    "dev:profile": "node ./scripts/profile-dev-rss.mjs --spawn-dev",
    "dev:profile:report": "node ./scripts/profile-dev-rss.mjs --report",
    "dev:watch-select": "node ./scripts/watch-select.mjs",
    "watch:packages": "node ./scripts/watch-packages.mjs",
    "watch:packages:legacy": "turbo run watch --filter='./packages/*' --concurrency=32",
    "build": "yarn build:packages && yarn generate && yarn build:packages && yarn build:app",
    "build:app": "turbo run build --filter=@open-mercato/app",
    "build:packages": "turbo run build --filter='./packages/*'",
    "lint": "turbo run lint",
    "lint:ds": "eslint --config eslint.ds.config.mjs packages/core/src/modules packages/enterprise/src/modules packages/ui/src/backend",
    "typecheck": "turbo run typecheck",
    "test": "cross-env NODE_OPTIONS=--max-old-space-size=768 turbo run test --concurrency=2",
    "start": "turbo run start --filter=@open-mercato/app",
    "generate": "turbo run generate --filter=@open-mercato/app",
    "reinstall": "turbo run reinstall --filter=@open-mercato/app",
    "db:generate": "yarn workspace @open-mercato/app db:generate",
    "db:migrate": "turbo run db:migrate --filter=@open-mercato/app",
    "db:greenfield": "turbo run db:greenfield --filter=@open-mercato/app",
    "initialize": "turbo run initialize --filter=@open-mercato/app",
    "seed:defaults": "yarn workspace @open-mercato/app seed:defaults",
    "docker:up": "docker compose -f docker-compose.fullapp.yml up --build -d",
    "docker:down": "docker compose -f docker-compose.fullapp.yml down",
    "docker:dev:up": "docker compose -f docker-compose.fullapp.dev.yml up --build -d",
    "docker:dev:down": "docker compose -f docker-compose.fullapp.dev.yml down",
    "docker:ephemeral": "docker compose -f docker-compose.preview.yaml up --build",
    "docker:ephemeral:down": "docker compose -f docker-compose.preview.yaml down",
    "docker:dev": "node scripts/docker-exec.mjs dev",
    "docker:build:packages": "node scripts/docker-exec.mjs build:packages",
    "docker:generate": "node scripts/docker-exec.mjs generate",
    "docker:initialize": "node scripts/docker-exec.mjs initialize",
    "docker:reinstall": "node scripts/docker-exec.mjs reinstall",
    "docker:db:migrate": "node scripts/docker-exec.mjs db:migrate",
    "docker:db:generate": "node scripts/docker-exec.mjs db:generate",
    "docker:lint": "node scripts/docker-exec.mjs lint",
    "docker:typecheck": "node scripts/docker-exec.mjs typecheck",
    "docker:test": "node scripts/docker-exec.mjs test",
    "docker:install-skills": "node scripts/docker-exec.mjs install-skills",
    "docker:mercato": "node scripts/docker-exec.mjs mercato",
    "docs:dev": "turbo run dev --filter=@open-mercato/docs",
    "clean:generated": "./scripts/clean-generated.sh",
    "clean:packages": "./scripts/clean-packages.sh",
    "clean": "yarn clean:generated && yarn clean:packages",
    "install-skills": "./scripts/install-skills.sh",
    "mcp:serve": "turbo run mcp:serve --filter=@open-mercato/ai-assistant",
    "mcp:dev": "turbo run mcp:dev --filter=@open-mercato/ai-assistant",
    "mercato": "node packages/cli/dist/bin.js",
    "registry:setup-user": "./scripts/registry/setup-user.sh",
    "registry:publish": "./scripts/registry/publish.sh",
    "release:snapshot": "./scripts/release-snapshot.sh",
    "release:existing": "./scripts/release-existing.sh",
    "release:patch": "./scripts/release-patch.sh",
    "release:minor": "./scripts/release-minor.sh",
    "release:major": "./scripts/release-major.sh",
    "i18n:check-sync": "tsx scripts/i18n-check-sync.ts",
    "i18n:check-usage": "tsx scripts/i18n-check-usage.ts",
    "i18n:check-hardcoded": "tsx scripts/i18n-check-hardcoded.ts",
    "i18n:check-values": "node scripts/i18n-check-values.mjs",
    "i18n:check": "tsx scripts/i18n-check-sync.ts && tsx scripts/i18n-check-usage.ts && tsx scripts/i18n-check-hardcoded.ts && node scripts/i18n-check-values.mjs",
    "i18n:fix": "tsx scripts/i18n-check-sync.ts --fix",
    "ds:mockups:snapshot": "tsx scripts/ds-mockups-snapshot.ts",
    "ds:mockups:draft": "tsx scripts/ds-mockups-draft.ts",
    "ds:mockups:promote": "tsx scripts/ds-mockups-promote.ts",
    "logger:check-console": "node scripts/logger-check-console.mjs",
    "logger:check-console:ci": "node scripts/logger-check-console.mjs --strict",
    "check:dep-versions": "tsx scripts/check-dep-versions.ts",
    "template:sync": "tsx scripts/template-sync.ts",
    "template:sync:fix": "tsx scripts/template-sync.ts --fix",
    "template:sync:ask": "tsx scripts/template-sync.ts --ask",
    "test:create-app": "tsx scripts/test-create-app.ts",
    "test:create-app:integration": "tsx scripts/test-create-app-integration.ts",
    "test:scripts": "node --test scripts/__tests__/*.test.mjs apps/mercato/scripts/__tests__/*.test.mjs",
    "official-modules": "node scripts/official-modules.mjs",
    "postinstall": "node scripts/official-modules-setup.mjs",
    "test:integration": "cross-env ENABLE_CRUD_API_CACHE=true npx playwright test --config .ai/qa/tests/playwright.config.ts",
    "test:integration:report": "npx playwright show-report .ai/qa/test-results/html",
    "test:integration:coverage": "yarn mercato test:integration:coverage",
    "test:integration:spec-coverage": "yarn mercato test:integration:spec-coverage",
    "test:integration:ephemeral": "cross-env ENABLE_CRUD_API_CACHE=true yarn mercato test:integration",
    "test:integration:ephemeral:interactive": "cross-env ENABLE_CRUD_API_CACHE=true yarn mercato test:integration:interactive",
    "test:integration:ephemeral:start": "cross-env ENABLE_CRUD_API_CACHE=true yarn mercato test:ephemeral",
    "test:integration:ephemeral:start:verbose": "cross-env ENABLE_CRUD_API_CACHE=true yarn mercato test:ephemeral --verbose",
    "prepare": "husky",
    "check:client-boundaries": "node scripts/check-client-boundaries.mjs",
    "check:client-boundaries:fail": "node scripts/check-client-boundaries.mjs --fail",
    "check:time-bombs": "node scripts/time-bomb-scanner.mjs",
    "check:time-bombs:fail": "node scripts/time-bomb-scanner.mjs --fail"
  },
