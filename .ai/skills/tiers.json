{
  "$schema": "./tiers.schema.json",
  "default": ["core"],
  "external": {
    "source": "open-mercato/skills",
    "description": "Skills installed from the shared open-mercato/skills collection via `npx skills add` (see scripts/install-skills.sh). A folder under .ai/skills/ matching one of these names is a repo-local override read by the external skill, never symlinked into the harness directories.",
    "skills": [
      "om-approve-merge-pr",
      "om-auto-continue-pr",
      "om-auto-continue-pr-loop",
      "om-auto-create-pr",
      "om-auto-create-pr-loop",
      "om-auto-fix-issue",
      "om-auto-review-pr",
      "om-auto-update-changelog",
      "om-auto-verify-pr-ui",
      "om-check-and-commit",
      "om-code-review",
      "om-fix",
      "om-followup-issue-from-pr",
      "om-integration-tests",
      "om-merge-buddy",
      "om-open-pr",
      "om-prepare-issue",
      "om-prepare-test-env",
      "om-review-prs",
      "om-root-cause",
      "om-setup-agent-pipeline",
      "om-spec-writing",
      "om-stabilize-ci",
      "om-sync-merged-pr-issues",
      "om-verify-in-repo"
    ]
  },
  "tiers": {
    "core": {
      "description": "Daily-driver skills installed by default.",
      "skills": [
        "om-ds-guardian",
        "om-backend-ui-design",
        "om-implement-spec",
        "om-pre-implement-spec",
        "om-smart-test",
        "om-create-agents-md",
        "om-skill-creator",
        "om-fix-specs",
        "om-migrate-mikro-orm",
        "om-create-ai-agent",
        "om-help"
      ]
    },
    "automation": {
      "description": "PR/issue automation skills. Opt-in; agent-driven workflows.",
      "skills": [
        "om-auto-fix-github",
        "om-auto-verify-and-fix-github",
        "om-auto-publish-pr",
        "om-auto-qa-scenarios"
      ]
    },
    "security": {
      "description": "Security audit skills. Opt-in.",
      "skills": ["om-auto-sec-report", "om-auto-sec-report-pr"]
    },
    "migration": {
      "description": "One-shot, version-pinned migrations. Install only when needed.",
      "skills": ["om-auto-upgrade-0.4.10-to-0.5.0"]
    },
    "infra": {
      "description": "Rare, special-case skills.",
      "skills": ["om-dev-container-maintenance", "om-integration-builder"]
    }
  }
}
