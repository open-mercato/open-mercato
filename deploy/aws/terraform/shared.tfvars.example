# Reference: how Open Mercato env vars map onto this Terraform.
# Copy per-env values into environments/<env>/terraform.tfvars (NON-SECRET only).
# Secret VALUES are seeded via deploy/aws/scripts/seed-secrets.sh — never here.

# ---- Set in terraform.tfvars (non-secret) ----
# region             = "us-east-1"
# name_prefix        = "om-prod"          # <= 28 chars (ALB/TG name limit)
# environment        = "prod"
# deployment_profile = "scale"            # economy | scale
# app_url            = "https://app.example.com"   # -> APP_URL / NEXT_PUBLIC_APP_URL
# certificate_arn    = "arn:aws:acm:...:certificate/..."
# image              = "ghcr.io/open-mercato/open-mercato:prod-abc1234"
# s3_bucket_name     = "om-prod-storage-unique"     # -> OM_INTEGRATION_STORAGE_S3_BUCKET
# alarm_email        = "ops@example.com"

# ---- Generated by Terraform, stored in Secrets Manager, injected as env ----
# DATABASE_URL                 (postgres://...:5432/open_mercato?sslmode=require)
# REDIS_URL                    (rediss://:...@...:6379)
# MEILISEARCH_API_KEY          (random 48-char; also used as MEILI_MASTER_KEY)

# ---- Set as plain env by the stack (non-secret) ----
# NODE_ENV=production  PORT=3000  CACHE_STRATEGY=redis  QUEUE_STRATEGY=async
# RATE_LIMIT_STRATEGY=redis  RATE_LIMIT_TRUST_PROXY_DEPTH=1  DB_SSL=true
# OM_SEARCH_ENABLED=true  MEILISEARCH_HOST=http://meilisearch.<name_prefix>.internal:7700
# OM_ENABLE_STORAGE_S3=true  OM_INTEGRATION_STORAGE_S3_REGION=<region>
# AUTO_SPAWN_WORKERS / AUTO_SPAWN_SCHEDULER  (true in economy, false in scale)

# ---- Seeded out-of-band via scripts/seed-secrets.sh ----
# JWT_SECRET
# AUTH_SECRET
# TENANT_DATA_ENCRYPTION_FALLBACK_KEY     # openssl rand -hex 32
# <ghcr pull>  { username, password=read:packages PAT }
#
# Optional extras (add names to extra_seeded_secrets, then seed):
# ANTHROPIC_API_KEY  OPENAI_API_KEY  RESEND_API_KEY
# OM_INTEGRATION_STRIPE_SECRET_KEY  OM_INTEGRATION_STRIPE_WEBHOOK_SECRET
